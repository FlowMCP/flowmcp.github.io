                defaultGroup: 'configurator'
            }, null, 2 )
        }
        const currentText = () => { const sel = selected(); return activeTab === 'skill' ? buildSkill( sel ) : ( activeTab === 'selection' ? buildSelection( sel ) : buildConfig( sel ) ) }
        const renderTab = () => {
            codeEl.textContent = currentText()
            const needs = selected().filter( ( x ) => x.access !== 'tool-keyless' )
            // query `modal` not `root`: the modal is portaled to <body> on open (Memo 124 Kap 8)
