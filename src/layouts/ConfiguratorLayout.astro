        }

        // ---- filtering ----
        const dataClassMatch = ( id, cat ) => id === 'opendata' ? true : ( id === 'geomob' ? ( cat === 'geo' || cat === 'mobility' ) : false )
        const filters = { dataclass: new Set( [ 'opendata' ] ), region: new Set( [ 'Berlin' ] ), access: new Set( [ 'tool-keyless' ] ), category: new Set() }
        let searchQ = ''
        let mobileLimit = true
        const MOBILE_CARDS = 6
        const noResults = root.querySelector( '[data-noresults]' )
        const railBtn = ( type, val ) => root.querySelector( `[data-filter-type="${type}"][data-filter-val="${val}"]` )
        const setFilterBtn = ( btn, on ) => { btn.setAttribute( 'aria-pressed', String( on ) ); btn.classList.toggle( 'cfg__filter--on', on ); const bx = btn.querySelector( '.cfg__fbox' ); if( bx ) { bx.innerHTML = svg( on ? 'square-check' : 'square', 15 ) } }

