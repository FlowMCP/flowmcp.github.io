            root.querySelector( '[data-cart-sources-lbl]' ).textContent = plural( sel.length, T.source, T.sources )
            root.querySelector( '[data-cart-empty]' ).hidden = sel.length > 0
            root.querySelector( '[data-export]' ).disabled = sel.length === 0
            const mobar = root.querySelector( '[data-mobar]' )
