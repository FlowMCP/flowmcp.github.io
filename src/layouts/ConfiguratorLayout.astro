            if( si ) { searchQ = si.value.trim().toLowerCase(); applyFilters() }
        } )

        // ---- export modal (with focus trap) ----
        const modal = root.querySelector( '[data-modal]' )
        const codeEl = root.querySelector( '[data-code]' )
        let activeTab = 'skill'
        let lastFocus = null
        // canonical agent-skill markdown (Memo 124 Kap 9, F6=C) — frontmatter + trigger +
        // behavioral rule (search -> call) + tool inventory + setup-by-access + forbidden patterns
        const buildSkill = ( sel ) => {
            const totalTools = sel.reduce( ( a, x ) => a + x.names.length, 0 )
            const keyed = sel.filter( ( x ) => x.access === 'tool-key' )
            const local = sel.filter( ( x ) => x.access === 'resource-local' )
            const allKeys = [ ...new Set( keyed.flatMap( ( x ) => x.keys ) ) ]
            const out = []
            out.push( '---' )
            out.push( 'name: flowmcp-selection' )
            out.push( 'description: ' + totalTools + ' FlowMCP tools across ' + sel.length + ' data sources, selected via the FlowMCP Configurator. Use when the task needs these APIs/data sources; call them through the FlowMCP CLI (search then call).' )
            out.push( '---' )
            out.push( '' )
            out.push( '# FlowMCP Selection' )
            out.push( '' )
            out.push( totalTools + ' tools across ' + sel.length + ' data sources, picked in the FlowMCP Configurator (demo; deterministically live-tested — not a quality grade).' )
            out.push( '' )
            out.push( '## Trigger' )
            out.push( '' )
            out.push( '- When the task needs one of these data sources: ' + sel.map( ( x ) => x.ns ).join( ', ' ) + '.' )
            out.push( '- When calling external data via FlowMCP.' )
            out.push( '' )
            out.push( '## Behavioral Rule' )
            out.push( '' )
            out.push( 'Tools run through the FlowMCP CLI — there is no activation step.' )
            out.push( '' )
            out.push( '1. **Search:** `flowmcp search <query>` — find the tool (each result carries `requiredParams` + `example`).' )
            out.push( "2. **Call:** `flowmcp call <tool-name> '{...}'` — call directly. A key-gated tool whose key is missing returns a friendly \"missing KEY\" message." )
            out.push( '' )
            out.push( '## Tools' )
            out.push( '' )
            sel.forEach( ( x ) => {
                const tag = x.access === 'tool-keyless' ? 'keyless' : ( x.access === 'tool-key' ? ( 'needs key' + ( x.keys.length ? ': ' + x.keys.join( ', ' ) : '' ) ) : 'local resource' )
                out.push( '### ' + x.ns + ( x.title ? ' — ' + x.title : '' ) + '  (' + tag + ')' )
                x.names.forEach( ( n ) => out.push( '- `' + x.ns + '/tool/' + n + '`' ) )
                out.push( '' )
            } )
            out.push( '## Setup' )
