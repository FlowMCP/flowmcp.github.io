    .cfg { --cfg-toolbar-h: 3.1rem; }
    .cfg__toolbar { position: sticky; top: var( --sl-nav-height, 4rem ); z-index: 30; background: var( --bg-canvas ); padding: 0.55rem 0; margin-bottom: 0.5rem; border-bottom: 1px solid var( --border ); }
