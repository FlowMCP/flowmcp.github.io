            }
        } )
        modal.querySelectorAll( '[data-tab]' ).forEach( ( b ) => b.addEventListener( 'click', () => { activeTab = b.dataset.tab; modal.querySelectorAll( '[data-tab]' ).forEach( ( x ) => { const on = x === b; x.classList.toggle( 'cfg__tab--active', on ); x.setAttribute( 'aria-selected', String( on ) ) } ); renderTab() } ) )
        root.querySelector( '[data-cfg-copy]' ).addEventListener( 'click', async ( e ) => { try { await navigator.clipboard.writeText( codeEl.textContent ); e.target.textContent = T.copied } catch ( err ) { e.target.textContent = '⚠' } finally { setTimeout( () => { e.target.textContent = T.copy }, 1400 ) } } )
        root.querySelector( '[data-download]' ).addEventListener( 'click', () => { const blob = new Blob( [ currentText() ], { type: 'text/plain' } ); const a = document.createElement( 'a' ); a.href = URL.createObjectURL( blob ); a.download = activeTab === 'skill' ? 'flowmcp-skill.md' : ( 'flowmcp-' + activeTab + '.json' ); a.click(); URL.revokeObjectURL( a.href ) } )

        // ---- mobile cart sheet ----
        const sheetOpen = () => root.classList.add( 'cfg--sheetopen' )
        const sheetClose = () => root.classList.remove( 'cfg--sheetopen' )
        root.querySelectorAll( '[data-sheet-open]' ).forEach( ( b ) => b.addEventListener( 'click', sheetOpen ) )
        document.addEventListener( 'click', ( e ) => {
            if( !root.classList.contains( 'cfg--sheetopen' ) ) { return }
            if( e.target.closest( '[data-export]' ) ) { sheetClose(); return }
            // tap outside the cart sheet (and not on the opener) closes it
            if( !e.target.closest( '.cfg__cart' ) && !e.target.closest( '[data-sheet-open]' ) ) { sheetClose() }
        } )
        document.addEventListener( 'keydown', ( e ) => { if( e.key === 'Escape' && root.classList.contains( 'cfg--sheetopen' ) ) { sheetClose() } } )

        window.addEventListener( 'resize', () => { applyFilters() } )
        applyFilters()
        renderCart()
    } )()
</script>

<!-- is:global — the configurator builds chips/cart-items/icons in client JS; Astro's
     scoped styles only tag server-rendered nodes, so those dynamic nodes would fall back
     to Starlight's prose defaults (the grey chip boxes bug). Every selector below is
     .cfg-prefixed, so going global is safe and styles dynamic nodes too. -->
<style is:global>
    /* Reset Starlight's .sl-markdown-content prose spacing that leaks into the embedded
     * configurator (it injects margins on every child → the over-large vertical gaps). */
    .cfg, .cfg * { box-sizing: border-box; }
    .cfg :where( h1, p, ul, ol, li, button, pre, input, header, footer, aside, main, div ) { margin: 0; }
    .cfg :where( ul, ol ) { padding-left: 0; list-style: none; }
    .cfg :where( button, input ) { font-family: inherit; line-height: 1.3; }

    /* Surface tokens. NOTE (C1): the whole FlowMCP site is intentionally dark-only —
     * custom.css maps the Starlight palette to the same dark values for both
     * [data-theme="light"] and "dark". The configurator deliberately follows that
     * (dark-only) instead of becoming a light island inside dark chrome. A real
     * light theme is a SITE-WIDE task (custom.css), tracked separately. */
    /* unified CI spacing (Memo 124 Kap 10, F7=C): blog-derived top/bottom margin + side padding;
     * the configurator keeps its own 1200px max-width. */
    .cfg { --status-ok: #3fb950; --status-warn: #e3b341; --cfg-faint: #8b96a3; --cfg-elev: #1c2433; --cfg-elev-2: #131a24; --cfg-chip-bg: #21262d; max-width: 1200px; margin: var( --page-mt, 2rem ) auto var( --page-mb, 4rem ); padding-inline: var( --page-pad-x, 1.5rem ); font-family: var( --sl-font, "Inter", sans-serif ); }
