                if( s === 'off' ) { tools.forEach( ( b ) => setTool( b, false ) ); syncCard( card ); renderCart() }
                else if( s === 'all' ) { tools.forEach( ( b ) => setTool( b, true ) ); syncCard( card ); renderCart() }
