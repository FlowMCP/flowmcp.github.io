                const sf = JSON.parse( starter.dataset.starter )
                if( sf.region ) { filters.region.add( sf.region ) }
                if( sf.access ) { filters.access.add( sf.access ) }
                if( sf.category ) { filters.category.add( sf.category ) }
                root.querySelectorAll( '[data-starter]' ).forEach( ( p ) => p.classList.remove( 'cfg__pill--on' ) )
                starter.classList.add( 'cfg__pill--on' )
                syncRail()
                applyFilters()
                return
            }
            if( e.target.closest( '[data-showmore]' ) ) { mobileLimit = false; applyFilters(); return }
            if( e.target.closest( '[data-add-recommended]' ) ) { recCards().forEach( ( c ) => { toolsOf( c ).forEach( ( b ) => setTool( b, true ) ); syncCard( c ) } ); renderCart(); return }
            if( e.target.closest( '[data-rail-toggle]' ) ) {
                const tg = e.target.closest( '[data-rail-toggle]' )
                const open = root.classList.toggle( 'cfg--railopen' )
                tg.setAttribute( 'aria-expanded', String( open ) )
                return
            }
            // cart chip remove (Memo 124 Kap 2) — X on a tool chip drops that tool, X on an "all N" chip drops the namespace
            const cx = e.target.closest( '[data-chip-ns]' )
            if( cx ) {
                const card = cards.find( ( c ) => c.dataset.ns === cx.dataset.chipNs )
                if( card ) {
                    if( cx.dataset.chipTool ) { const b = toolsOf( card ).find( ( t ) => t.dataset.tool === cx.dataset.chipTool ); if( b ) { setTool( b, false ) } }
                    else { toolsOf( card ).forEach( ( b ) => setTool( b, false ) ) }
                    syncCard( card ); renderCart()
                }
                return
            }
            const tb = e.target.closest( '[data-tool-check]' )
            if( tb ) { setTool( tb, !isOn( tb ) ); syncCard( tb.closest( '.cfg__card' ) ); renderCart(); return }
            // Off/Some/All segment control (Memo 124 Kap 1) — off=deselect all, all=select all, some=display-only
            const seg = e.target.closest( '[data-seg]' )
            if( seg ) {
