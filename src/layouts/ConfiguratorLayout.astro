            }
            const sa = e.target.closest( '[data-selectall]' )
            if( sa ) { const card = sa.closest( '.cfg__card' ); const tools = toolsOf( card ); const on = tools.some( ( b ) => !isOn( b ) ); tools.forEach( ( b ) => setTool( b, on ) ); syncCard( card ); renderCart(); return }
            // whole card header row toggles the toolbox (checkbox already returned above)
