            card.classList.toggle( 'cfg__card--selected', sel > 0 )
            const sa = card.querySelector( '[data-selectall]' )
            if( sa ) { sa.textContent = ( sel === tools.length && tools.length > 0 ) ? T.deselectAllTools : T.selectAllTools }
            // per-card selection detail lives in the expanded toolhead only — the namespace-desc
            // counter was removed (the segment control carries that state now, Memo 124 Kap 1/3)
            const selInfo = card.querySelector( '[data-sel-info]' )
