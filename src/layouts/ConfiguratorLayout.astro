            out.push( '' )
            out.push( '## Forbidden Patterns' )
            out.push( '' )
            out.push( '- NEVER use `flowmcp add` / `group` / `import` (removed — no activation, no registry).' )
            out.push( '- NEVER construct tool refs or schema paths manually — discover them via `flowmcp search`.' )
            out.push( '- NEVER pipe `flowmcp` output through `node -e` or guess flags.' )
            return out.join( '\n' )
        }
        const buildSelection = ( sel ) => JSON.stringify( { selection: sel.map( ( x ) => ( { namespace: x.ns, tools: x.names } ) ) }, null, 2 )
        // valid .flowmcp/config.json (Memo 124 Kap 9) — root + envPath + tools[] using the
