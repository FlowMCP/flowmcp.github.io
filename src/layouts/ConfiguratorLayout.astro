---
// ConfiguratorLayout.astro — Memo 121, Stufe 2 (interactive).
// Embedded in the Starlight frame via <StarlightPage> so the global Header/Footer
// apply unchanged (Memo 121 Kap. 2). The duplicate splash <h1 id="_top"> + its
// content-panel divider are suppressed centrally in custom.css (body:has(.cfg) …).
//
// FilterRail (left) = Region · Data class · Category filters. Catalog (middle) =
// namespace cards, tools collapsed by default. Cart (right) = live selection +
// readiness + export modal. On mobile the cart collapses to a bottom bar + sheet,
// the rail collapses behind a "Filters" toggle. All vanilla JS (no framework).
// Honesty: "live-tested" (deterministic), never a quality grade.

import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro'
import payload from '../data/configurator-payload.json'

const { lang = 'en' } = Astro.props

const t = lang === 'de'
    ? { title: 'Configurator', startWith: 'Starten mit:', sources: 'Quellen', source: 'Quelle', tools: 'Tools', tool: 'Tool', liveTested: 'live getestet', needsKey: 'braucht Key', local: 'lokal', cart: 'Dein Agent-Toolset', cartSubLine: 'Berlin Open Data · frei, nichts zu kaufen', exp2: 'Keine Installation — fertige Agent-Skill + kurze Anleitung.', cartEmpty: 'Noch nichts ausgewählt.', region: 'REGION', dataClass: 'DATENKLASSE', access: 'ZUGANG', category: 'KATEGORIE', clear: 'zurücksetzen', filterSources: 'Quellen filtern…', demo: 'DEMO-DATEN · JSON', exportBtn: 'Als Skill exportieren', readyOk: 'Bereit — kein Setup nötig', readyWarn: 'Setup nötig, bevor das läuft', selectedTools: 'AUSGEWÄHLTE TOOLS', tabSkill: 'Agent Skill', tabSel: 'flowmcp-Auswahl', tabCfg: 'Config JSON', copy: 'Kopieren', copied: 'Kopiert!', download: '.md laden', close: 'Schließen', emptyHint: 'Wähle Tools, dann hier exportieren.', dataSources: 'Datenquellen', legFree: 'frei · live getestet', legKey: 'braucht API-Key', legLocal: 'lokale Ressource', noResults: 'Keine Quellen für diese Filter.', filterN: '{n} Tools filtern…', selectAllTools: 'Alle wählen', deselectAllTools: 'Alle abwählen', segOff: 'Aus', segSome: 'Teils', segAll: 'Alle', selOf: '{n} von {m} gewählt', selOfTools: '{n} von {m} Tools gewählt', parameters: 'PARAMETER', required: 'erforderlich', optional: 'optional', subLine: 'Durchsuche FlowMCPs Datenquellen, wähle die Tools, die dein Agent braucht, und exportiere eine fertige Auswahl.', metaSources: 'offene Quellen', metaVerified: 'deterministisch verifiziert', modalTitle: 'Exportiere dein Agent-Toolset', howToUse: 'SO GEHT\'S', howToText: 'Füge die Agent-Skill in deinen Agenten ein oder kopiere die flowmcp-Auswahl in deine Config. Keyless-Tools laufen sofort; keyed-Tools brauchen ihren API-Key.', disclaimer: '„live getestet“ heißt: der deterministische Test war grün (HTTP 200 + Daten). Es ist KEINE Qualitätsbewertung — LLM-Grading steht noch aus.', allRegions: 'Alle Regionen', allSources: 'Alle Quellen', removeFilter: 'Filter entfernen', filtersBtn: 'Filter', toolset: 'Toolset', selected: 'ausgewählt', tapClose: '· zum Schließen daneben tippen ·', showMore: '{n} weitere Quellen zeigen', shownOf: '{shown} von {total} Quellen', scopedTo: 'Eingegrenzt auf', addRec: '{n} empfohlene hinzufügen', addRecDone: '{n} empfohlene hinzugefügt', allN: 'alle {n}', removeTool: 'Tool entfernen', regions: { Berlin: 'Berlin', Germany: 'Deutschland', global: 'Global' } }
    : { title: 'Configurator', startWith: 'Start with:', sources: 'sources', source: 'source', tools: 'tools', tool: 'tool', liveTested: 'live-tested', needsKey: 'needs key', local: 'local', cart: 'Your agent toolset', cartSubLine: 'Berlin Open Data · free, nothing to buy', exp2: 'No install — get a ready-to-paste agent skill + short setup guide.', cartEmpty: 'Nothing selected yet.', region: 'REGION', dataClass: 'DATA CLASS', access: 'ACCESS', category: 'CATEGORY', clear: 'clear', filterSources: 'Filter sources…', demo: 'DEMO DATA · JSON', exportBtn: 'Export as Skill', readyOk: 'Ready to use — no setup needed', readyWarn: 'Setup needed before this runs', selectedTools: 'SELECTED TOOLS', tabSkill: 'Agent Skill', tabSel: 'flowmcp selection', tabCfg: 'Config JSON', copy: 'Copy', copied: 'Copied!', download: 'Download .md', close: 'Close', emptyHint: 'Select tools, then export here.', dataSources: 'Data sources', legFree: 'free · live-tested', legKey: 'needs API key', legLocal: 'local resource', noResults: 'No sources match these filters.', filterN: 'Filter {n} tools…', selectAllTools: 'Select all', deselectAllTools: 'Deselect all', segOff: 'Off', segSome: 'Some', segAll: 'All', selOf: '{n} of {m} selected', selOfTools: '{n} of {m} tools selected', parameters: 'PARAMETERS', required: 'required', optional: 'optional', subLine: "Search FlowMCP's data sources, pick the tools your agent needs, and export a ready-to-use selection.", metaSources: 'open sources', metaVerified: 'deterministically verified', modalTitle: 'Export your agent toolset', howToUse: 'HOW TO USE', howToText: 'Paste the Agent Skill into your agent, or copy the flowmcp selection into your config. Keyless tools run immediately; keyed tools need their API key.', disclaimer: '“live-tested” means the deterministic test passed (HTTP 200 + data). It is NOT a quality grade — LLM grading is still pending.', allRegions: 'All regions', allSources: 'All sources', removeFilter: 'remove filter', filtersBtn: 'Filters', toolset: 'Toolset', selected: 'selected', tapClose: '· tap outside to close ·', showMore: 'Show {n} more sources', shownOf: '{shown} of {total} sources', scopedTo: 'Scoped to', addRec: 'Add {n} recommended', addRecDone: '{n} recommended added', allN: 'all {n}', removeTool: 'Remove tool', regions: { Berlin: 'Berlin', Germany: 'Germany', global: 'Global' } }

const { meta, accessClasses, categories, regions, collections, sources } = payload

const totalTools = sources.reduce( ( acc, s ) => acc + s.toolCount, 0 )
const detCount = sources.filter( ( s ) => s.detVerified ).length
const countRegion = ( r ) => sources.filter( ( s ) => s.region === r ).length

// one-line display description (first sentence, capped)
const shortDesc = ( d ) => {
    const first = String( d || '' ).split( /(?<=\.)\s/ )[ 0 ]
    return first.length > 140 ? first.slice( 0, 137 ).trimEnd() + '…' : first
}

// inline lucide SVG paths (single source — the client script reuses these via #cfg-icons)
const LUCIDE = {
    'chevron-right': '<path d="m9 18 6-6-6-6"/>',
    'chevron-down': '<path d="m6 9 6 6 6-6"/>',
    'square': '<rect width="18" height="18" x="3" y="3" rx="2"/>',
    'square-check': '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/>',
    'square-minus': '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M8 12h8"/>',
    'search': '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
    'map-pin': '<path d="M20 10c0 4.4-8 12-8 12s-8-7.6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
    'shopping-cart': '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>',
    'triangle-alert': '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
    'circle-check': '<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>',
    'key-round': '<path d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"/><circle cx="16.5" cy="7.5" r=".5" fill="currentColor"/>',
    'check': '<path d="M20 6 9 17l-5-5"/>',
    'sparkles': '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"/>',
    'filter': '<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>',
    'x': '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>'
}
const icon = ( name, size = 16 ) => `<svg class="ic" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${LUCIDE[ name ] || ''}</svg>`

// status marker matching the legend exactly (T6): free=green dot, key=key icon,
// local=square swatch; an extra check appears when the source is deterministically tested.
const statusMarker = ( s ) => {
    const ver = s.detVerified ? `<span class="cfg__veric" title="${t.liveTested}">${icon( 'check', 11 )}</span>` : ''
    if( s.access === 'tool-key' ) { return `<span class="cfg__legkey" title="${t.needsKey}">${icon( 'key-round', 13 )}</span>${ver}` }
    if( s.access === 'resource-local' ) { return `<span class="cfg__leglocal" title="${t.local}"></span>${ver}` }
    return `<span class="cfg__dot cfg__dot--ok" title="${t.legFree}"></span>${ver}`
}

// FilterRail category taxonomy — canonical categories from the payload, only those that
// actually have sources (replaces the redundant "Data Class" section, Memo 124 Kap 6)
const railCategories = categories
    .map( ( c ) => ( { id: c.id, label: c.name, count: sources.filter( ( s ) => s.category === c.id ).length } ) )
    .filter( ( c ) => c.count > 0 )
// region values in the data are Berlin / Germany / global — labels match the data (T6/A12)
const railRegions = [
    { id: 'Berlin', on: true },
    { id: 'Germany' },
    { id: 'global' }
].map( ( r ) => ( { ...r, label: t.regions[ r.id ], count: countRegion( r.id ) } ) )
const railAccess = [
    { id: 'tool-keyless', label: lang === 'de' ? 'Keyless (sofort nutzbar)' : 'Keyless (ready to use)', on: true },
    { id: 'tool-key', label: lang === 'de' ? 'Braucht API-Key' : 'Needs API key' },
    { id: 'resource-local', label: lang === 'de' ? 'Lokale Ressource' : 'Local resource' }
]

// label maps handed to the client for dynamic headline/chips (T4)
const cfgConfig = {
    regions: t.regions,
    access: { 'tool-keyless': railAccess[ 0 ].label, 'tool-key': railAccess[ 1 ].label, 'resource-local': railAccess[ 2 ].label },
    dataclass: { opendata: 'Open Data', geomob: 'Geo / Mobility' },
    categories: Object.fromEntries( categories.map( ( c ) => [ c.id, c.name ] ) ),
    defaults: { region: 'Berlin', access: 'tool-keyless', dataclass: 'opendata' }
}

const frontmatter = { title: t.title, description: t.subLine, template: 'splash', tableOfContents: false, pagefind: false }
---

<StarlightPage frontmatter={frontmatter}>
    <div class="cfg" id="cfg-root" lang={lang}>
        <header class="cfg__intro">
            <div class="cfg__titlerow">
                <h1 class="cfg__h1">{t.title}</h1>
                <span class="cfg__demobadge" title={t.disclaimer}>{t.demo}</span>
            </div>
            <p class="cfg__sub">{t.subLine}</p>
            <div class="cfg__meta">{sources.length} {t.metaSources} · {totalTools} {t.tools} · {detCount} {t.metaVerified}</div>
            <p class="cfg__disclaimer"><span class="cfg__disc-ic" set:html={icon( 'triangle-alert', 13 )} /> {t.disclaimer}</p>
        </header>

        <!-- sticky "Start with" toolbar (Memo 124 Kap 5) — pins below the nav on scroll -->
        <div class="cfg__toolbar">
            <div class="cfg__starters">
                <span class="cfg__starters-lbl">{t.startWith}</span>
                {collections.map( ( c, i ) => (
                    <button type="button" class={`cfg__pill ${i === 0 ? 'cfg__pill--on' : ''}`} data-starter={JSON.stringify( c.filters || {} )}>
                        <span class="cfg__pillcheck" set:html={icon( 'check', 13 )} />{c.label}
                    </button>
                ) )}
            </div>
        </div>

        <div class="cfg__work">
            <!-- mobile-only filter toggle -->
            <!-- mobile: Filters button + active-filter chips share ONE horizontal scroll row -->
            <div class="cfg__mfilters">
                <button type="button" class="cfg__railtoggle" data-rail-toggle aria-expanded="false" aria-controls="cfg-rail">
                    <span set:html={icon( 'filter', 15 )} /> {t.filtersBtn} <span class="cfg__railtoggle-n" data-rail-count></span>
                </button>
                <div class="cfg__activefilters cfg__activefilters--mobile" data-active-filters></div>
            </div>

            <!-- FilterRail -->
            <aside class="cfg__rail" id="cfg-rail">
                <div class="cfg__scopechip">
                    <span class="cfg__scopel"><span set:html={icon( 'map-pin', 12 )} /> <span class="cfg__scopetxt" data-scope-label>{t.scopedTo} {t.regions.Berlin}</span></span>
                    <button type="button" class="cfg__scopex" data-reset>{t.clear}</button>
                </div>
                <div class="cfg__activefilters" data-active-filters></div>
                <div class="cfg__search">
                    <span set:html={icon( 'search', 14 )} />
                    <input type="text" class="cfg__searchinput" placeholder={t.filterSources} data-search aria-label={t.filterSources} />
                </div>

                <div class="cfg__microlabel">{t.category}</div>
                {railCategories.map( ( c ) => (
                    <button type="button" class="cfg__filter" data-filter-type="category" data-filter-val={c.id} aria-pressed="false">
                        <span class="cfg__fbox" set:html={icon( 'square', 15 )} /><span class="cfg__flabel">{c.label}</span><span class="cfg__fcount">{c.count}</span>
                    </button>
                ) )}

                <div class="cfg__microlabel">{t.region}</div>
                {railRegions.map( ( r ) => (
                    <button type="button" class={`cfg__filter ${r.on ? 'cfg__filter--on' : ''}`} data-filter-type="region" data-filter-val={r.id} aria-pressed={r.on ? 'true' : 'false'}>
                        <span class="cfg__fbox" set:html={icon( r.on ? 'square-check' : 'square', 15 )} /><span class="cfg__flabel">{r.label}</span><span class="cfg__fcount">{r.count}</span>
                    </button>
                ) )}

                <div class="cfg__microlabel">{t.access}</div>
                {railAccess.map( ( a ) => (
                    <button type="button" class={`cfg__filter ${a.on ? 'cfg__filter--on' : ''}`} data-filter-type="access" data-filter-val={a.id} aria-pressed={a.on ? 'true' : 'false'}>
                        <span class="cfg__fbox" set:html={icon( a.on ? 'square-check' : 'square', 15 )} /><span class="cfg__flabel">{a.label}</span>
                    </button>
                ) )}
            </aside>

            <!-- Catalog -->
            <main class="cfg__catalog">
                <div class="cfg__cathead">
                    <span class="cfg__cathl" data-headline>{t.dataSources} · {t.regions.Berlin}</span>
                    <button type="button" class="cfg__addrec" data-add-recommended hidden></button>
                </div>
                <div class="cfg__legend">
                    <span><span class="cfg__dot cfg__dot--ok"></span> {t.legFree}</span>
                    <span><span class="cfg__legkey" set:html={icon( 'key-round', 12 )} /> {t.legKey}</span>
                    <span><span class="cfg__leglocal"></span> {t.legLocal}</span>
                    <span class="cfg__catcount" data-shown-count></span>
                </div>
                <ul class="cfg__cards">
                    {sources.map( ( s ) => (
                        <li class={`cfg__card cfg__card--${s.access}`} data-ns={s.namespace} data-access={s.access} data-region={s.region} data-category={s.category} data-keys={( s.keys || [] ).join( ',' )} data-verified={s.detVerified ? '1' : '0'} data-label={s.title} data-title={s.title.toLowerCase()} data-desc={( s.desc || '' ).toLowerCase()}>
                            <div class="cfg__card-top">
                                <div class="cfg__nsleft">
                                    <button type="button" class="cfg__expand" aria-label={lang === 'de' ? 'Tools anzeigen' : 'Show tools'} aria-expanded="false" data-expand><span class="cfg__chev" set:html={icon( 'chevron-right', 16 )} /></button>
                                    <span class="cfg__ns">{s.namespace}</span>
                                    <span class="cfg__badge">{s.toolCount} {s.toolCount === 1 ? t.tool : t.tools}</span>
                                    <span class="cfg__status" set:html={statusMarker( s )} />
                                </div>
                                <div class="cfg__seg" role="group" data-ns-seg aria-label={`${lang === 'de' ? 'Auswahl für' : 'Selection for'} ${s.namespace}`}>
                                    <button type="button" class="cfg__segbtn cfg__segbtn--on" data-seg="off" aria-pressed="true">{t.segOff}</button>
                                    <button type="button" class="cfg__segbtn" data-seg="some" aria-pressed="false" tabindex="-1" aria-hidden="true">{t.segSome}</button>
                                    <button type="button" class="cfg__segbtn" data-seg="all" aria-pressed="false">{t.segAll}</button>
                                </div>
                            </div>
                            <p class="cfg__desc" title={s.desc}>{shortDesc( s.desc )}</p>
                            <div class="cfg__toolbox" hidden>
                                <div class="cfg__toolhead">
                                    <span class="cfg__toolfilter">
                                        <span set:html={icon( 'search', 13 )} />
                                        <input type="text" class="cfg__toolfilterinput" data-tool-search placeholder={t.filterN.replace( '{n}', s.toolCount )} aria-label={t.filterN.replace( '{n}', s.toolCount )} />
                                    </span>
                                    <span class="cfg__selwrap"><span class="cfg__selinfo" data-sel-info></span><button type="button" class="cfg__selectall" data-selectall>{t.selectAllTools}</button></span>
                                </div>
                                <ul class="cfg__tools">
                                    {s.tools.map( ( tool ) => (
                                        <li class="cfg__tool" data-tool-name={tool.name.toLowerCase()} data-tool-desc={( tool.desc || '' ).toLowerCase()}>
                                            <div class="cfg__toolrow">
                                                <button type="button" class="cfg__toolcheck" role="checkbox" aria-checked="false" data-tool-check data-tool={tool.name} aria-label={tool.name} set:html={icon( 'square', 15 )} />
                                                <span class="cfg__toolname" title={tool.name}>{tool.name}</span>
                                                <span class="cfg__tooldesc" title={tool.desc}>{shortDesc( tool.desc )}</span>
                                                <button type="button" class="cfg__toolexpand" data-tool-expand aria-expanded="false" aria-label={lang === 'de' ? 'Details anzeigen' : 'Show details'}><span class="cfg__tchev" set:html={icon( 'chevron-right', 14 )} /></button>
                                            </div>
                                            <div class="cfg__tooldetail" hidden>
                                                <p class="cfg__exd">{tool.desc}</p>
                                                {tool.params && tool.params.length > 0 ? (
                                                    <Fragment>
                                                        <div class="cfg__plabel">{t.parameters}</div>
                                                        {tool.params.map( ( p ) => (
                                                            <div class="cfg__prow">
                                                                <span class="cfg__pn">{p.name}</span>
                                                                <span class={`cfg__pt ${p.required ? 'cfg__pt--req' : ''}`}>{p.type} · {p.required ? t.required : t.optional}</span>
                                                                <span class="cfg__pd">{p.note}</span>
                                                            </div>
                                                        ) )}
                                                    </Fragment>
                                                ) : null}
                                            </div>
                                        </li>
                                    ) )}
                                </ul>
                            </div>
                        </li>
                    ) )}
                </ul>
                <button type="button" class="cfg__showmore" data-showmore hidden></button>
                <p class="cfg__noresults" data-noresults hidden>
                    {t.noResults} <button type="button" class="cfg__noresets" data-reset>{t.clear}</button>
                </p>
            </main>

            <!-- Cart (desktop side panel; becomes a bottom sheet on mobile) -->
            <aside class="cfg__cart" id="cfg-cart">
                <div class="cfg__cart-head"><span class="cfg__carticon" set:html={icon( 'shopping-cart', 16 )} /> {t.cart}</div>
                <p class="cfg__cart-sub">{t.cartSubLine}</p>
                <div class="cfg__cart-scroll">
                    <div class="cfg__cart-meta"><strong data-cart-tools>0</strong> <span data-cart-tools-lbl>{t.tools}</span> · <strong data-cart-sources>0</strong> <span data-cart-sources-lbl>{t.sources}</span></div>
                    <p class="cfg__cart-empty" data-cart-empty>{t.cartEmpty}</p>
                    <div class="cfg__readiness" data-readiness hidden>
                        <div class="cfg__readiness-top" data-readiness-top></div>
                        <div class="cfg__readiness-legend" data-readiness-legend></div>
                    </div>
                    <div class="cfg__microlabel" data-chips-label hidden>{t.selectedTools}</div>
                    <div class="cfg__chips" data-chips></div>
                </div>
                <button type="button" class="cfg__export" data-export disabled><span set:html={icon( 'sparkles', 14 )} /> {t.exportBtn}</button>
                <p class="cfg__exp2">{t.exp2}</p>
            </aside>
        </div>

        <!-- Mobile bottom cart bar (Pencil 2HEe5) — visibility is viewport-driven (CSS) -->
        <div class="cfg__mobar" data-mobar>
            <div class="cfg__mobar-lbl">
                <strong><span data-mobar-tools>0</span> <span data-mobar-tools-lbl>{t.tools}</span> {t.selected}</strong>
                <span class="cfg__mobar-sub">{t.cartSubLine}</span>
            </div>
            <button type="button" class="cfg__mobar-btn" data-sheet-open><span set:html={icon( 'shopping-cart', 14 )} /> {t.toolset}</button>
        </div>

        <footer class="cfg__note">{meta.note}</footer>

        <!-- Export modal -->
        <div class="cfg__modal" data-modal hidden>
            <div class="cfg__backdrop" data-modal-close></div>
            <div class="cfg__modalcard" role="dialog" aria-modal="true" aria-labelledby="cfg-modal-title">
                <div class="cfg__modalhead">
                    <span id="cfg-modal-title">{t.modalTitle}</span>
                    <button type="button" class="cfg__x" data-modal-close aria-label={t.close} set:html={icon( 'x', 16 )} />
                </div>
                <div class="cfg__tabs" role="tablist">
                    <button type="button" class="cfg__tab cfg__tab--active" data-tab="skill" role="tab" aria-selected="true">{t.tabSkill}</button>
                    <button type="button" class="cfg__tab" data-tab="selection" role="tab" aria-selected="false">{t.tabSel}</button>
                    <button type="button" class="cfg__tab" data-tab="config" role="tab" aria-selected="false">{t.tabCfg}</button>
                </div>
                <pre class="cfg__code" data-code tabindex="0"></pre>
                <div class="cfg__howto">
                    <div class="cfg__plabel">{t.howToUse}</div>
                    <p class="cfg__howtotext">{t.howToText}</p>
                </div>
                <div class="cfg__modalfoot">
                    <span class="cfg__hint" data-modal-hint></span>
                    <span class="cfg__modalbtns">
                        <button type="button" class="cfg__download" data-download>{t.download}</button>
                        <button type="button" class="cfg__copy" data-cfg-copy>{t.copy}</button>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <script type="application/json" id="cfg-payload" set:html={JSON.stringify( { sources: sources.map( ( s ) => ( { namespace: s.namespace, title: s.title } ) ) } )} />
    <script type="application/json" id="cfg-i18n" set:html={JSON.stringify( t )} />
    <script type="application/json" id="cfg-cfg" set:html={JSON.stringify( cfgConfig )} />
    <script type="application/json" id="cfg-icons" set:html={JSON.stringify( LUCIDE )} />
</StarlightPage>

<script is:inline>
    ;( () => {
        const root = document.getElementById( 'cfg-root' )
        if( !root ) { return }
        const T = JSON.parse( document.getElementById( 'cfg-i18n' ).textContent )
        const CFG = JSON.parse( document.getElementById( 'cfg-cfg' ).textContent )
        const ICONS = JSON.parse( document.getElementById( 'cfg-icons' ).textContent )
        const titleByNs = new Map( JSON.parse( document.getElementById( 'cfg-payload' ).textContent ).sources.map( ( s ) => [ s.namespace, s.title ] ) )

        // single icon source shared with the server (G2)
        const svg = ( name, size ) => `<svg class="ic" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${ICONS[ name ] || ''}</svg>`
