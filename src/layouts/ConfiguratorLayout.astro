        const openModal = () => { if( selected().length === 0 ) { return } lastFocus = document.activeElement; if( modal.parentElement !== document.body ) { document.body.appendChild( modal ) } modal.hidden = false; lockScroll( true ); renderTab(); const f = focusables(); if( f[ 0 ] ) { f[ 0 ].focus() } }
        const closeModal = () => { modal.hidden = true; lockScroll( false ); if( lastFocus ) { lastFocus.focus() } }
