            root.querySelectorAll( '[data-mobar-tools]' ).forEach( ( e ) => e.textContent = String( toolCount ) )
            root.querySelectorAll( '[data-mobar-tools-lbl]' ).forEach( ( e ) => e.textContent = plural( toolCount, T.tool, T.tools ) )
            root.querySelector( '[data-cart-tools-lbl]' ).textContent = plural( toolCount, T.tool, T.tools )
