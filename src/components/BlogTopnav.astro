---
// BlogTopnav — standalone clone of Header.astro for non-Starlight blog pages.
// Memo 059 Follow-up: previously diverged from main Header (different padding,
// missing v4-badge, missing LanguageSelect). This rewrite mirrors Header.astro
// HTML structure + class names so the global .pencil-header CSS applies.
//
// Why a clone instead of importing Header: Header.astro pulls from
// `virtual:starlight/...` which only resolves inside Starlight-rendered pages.
// The blog pages are standalone Astro pages, so we replicate the structure
// here and reuse the same class names (`.pencil-header`, `.header__nav-link`,
// etc.) which are already defined globally — see custom.css.

const { active = 'blog' } = Astro.props

const path = Astro.url.pathname
const isDE = path.startsWith( '/de/' ) || path === '/de'
const prefix = isDE ? '/de' : ''

const navLinks = isDE ? [
    { id: 'about', text: 'Über',  href: prefix + '/about/',                      match: '/about' },
    { id: 'docs',  text: 'Docs',  href: prefix + '/quickstart/what-is-flowmcp/', match: '/quickstart' },
    { id: 'blog',  text: 'Blog',  href: prefix + '/blog/',                       match: '/blog' }
] : [
    { id: 'about', text: 'About', href: prefix + '/about/',                      match: '/about' },
    { id: 'docs',  text: 'Docs',  href: prefix + '/quickstart/what-is-flowmcp/', match: '/quickstart' },
    { id: 'blog',  text: 'Blog',  href: prefix + '/blog/',                       match: '/blog' }
]

const homeHref = isDE ? '/de/' : '/'
// Blog has only EN content; toggling to DE goes to the DE landing page.
// From a (hypothetical) /de/blog/ we'd send the user back to the EN blog.
const otherLocaleHref = isDE ? '/blog/' : '/de/'
const otherLocaleLabel = isDE ? 'English' : 'Deutsch'
const currentLocaleLabel = isDE ? 'Deutsch' : 'English'
---

<div class="header pencil-header blog-pencil-header">
    <div class="header__left">
        <a class="title-wrapper sl-flex blog-topnav__brand" href={homeHref} aria-label="FlowMCP Home">
            <img src="/logo.svg" alt="" width="24" height="24" />
            <span class="site-title">FlowMCP</span>
            <span class="v4-badge">v4</span>
        </a>
        <nav class="header__nav sl-hidden md:sl-flex" aria-label="Main navigation">
            {navLinks.map( ( link ) => (
                <a
                    href={link.href}
                    class={`header__nav-link ${active === link.id || path.indexOf( link.match ) !== -1 ? 'is-active' : ''}`}
                    aria-current={active === link.id ? 'page' : undefined}
                >
                    {link.text}
                </a>
            ) )}
        </nav>
    </div>

    <div class="sl-flex print:hidden header__search blog-topnav__search-placeholder" aria-hidden="true">
        <!-- Search lives in Starlight virtuals; on standalone blog pages we
             render a non-functional placeholder so the 3-column grid stays
             aligned with the rest of the site. -->
    </div>

    <div class="sl-hidden md:sl-flex print:hidden right-group blog-topnav__locale">
        <div class="starlight-LanguageSelect">
            <details class="blog-locale">
                <summary aria-label="Select language" title={`Current language: ${currentLocaleLabel}`}>{currentLocaleLabel}</summary>
                <ul>
                    <li><a href={otherLocaleHref}>{otherLocaleLabel}</a></li>
                </ul>
            </details>
        </div>
    </div>
</div>

<style>
/* Mirror of Header.astro local styles. Kept inline so a single import is
 * enough; rules cascade into the same .pencil-header class also used by the
 * Starlight Header. */
.pencil-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    padding: 0 1rem;
    background: var(--bg-canvas);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 50;
    min-height: 60px;
}

.header__left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

.title-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
    text-decoration: none;
}

.site-title {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.01em;
}

.v4-badge {
    display: inline-block;
    padding: 2px 7px;
    background: var(--sidebar-active-bg);
    color: var(--accent);
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    line-height: 1;
}

.header__nav {
    display: flex;
    gap: 1.25rem;
    align-items: center;
}

.header__nav-link {
    color: var(--text-inactive);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.15s;
}

.header__nav-link:hover {
    color: var(--text-primary);
}

.header__nav-link.is-active {
    color: var(--text-primary);
    font-weight: 600;
}

.header__search {
    justify-self: end;
    max-width: 220px;
}

.right-group {
    gap: 0.75rem;
    align-items: center;
}

.blog-locale {
    position: relative;
    font-size: 14px;
}

.blog-locale > summary {
    list-style: none;
    cursor: pointer;
    color: var(--text-inactive);
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
}

.blog-locale > summary::-webkit-details-marker { display: none; }

.blog-locale[open] > summary {
    color: var(--text-primary);
}

.blog-locale > ul {
    position: absolute;
    right: 0;
    top: calc( 100% + 4px );
    margin: 0;
    padding: 0.25rem 0;
    list-style: none;
    background: var(--bg-canvas);
    border: 1px solid var(--border);
    border-radius: 4px;
    min-width: 8rem;
    z-index: 60;
}

.blog-locale > ul > li > a {
    display: block;
    padding: 0.4rem 0.75rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 14px;
}

.blog-locale > ul > li > a:hover {
    background: var(--sidebar-active-bg);
    color: var(--accent);
}

@media (max-width: 50rem) {
    .header__left {
        gap: 0.5rem;
    }
    .v4-badge {
        font-size: 9px;
        padding: 1px 5px;
    }
    .header__search {
        max-width: 100%;
    }
}
</style>
