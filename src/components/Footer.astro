---
// Custom Footer — Pencil-Stil (Mockup Gdy0k Bottom)
// Memo 059 PRD-012: 3-column widget (Project / Resources / Community).
// PRD-013 audit: DE-Mirror complete — labels + hrefs locale-aware via isDE.
// Both locales render 3 columns. DE labels: Projekt/Ressourcen/Community.
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const isDE = path.startsWith('/de/') || path === '/de';
const prefix = isDE ? '/de' : '';

const copy = `© ${year} FlowMCP · MIT`;

const t = isDE ? {
    project: 'Projekt',
    resources: 'Ressourcen',
    community: 'Community',
    about: 'Ueber',
    blog: 'Blog',
    license: 'Lizenz',
    quickstart: 'Schnellstart',
    specification: 'Spezifikation',
    configurator: 'Data Configurator',
    roadmap: 'Roadmap',
    team: 'Team',
    github: 'GitHub',
} : {
    project: 'Project',
    resources: 'Resources',
    community: 'Community',
    about: 'About',
    blog: 'Blog',
    license: 'License',
    quickstart: 'Quickstart',
    specification: 'Specification',
    configurator: 'Data Configurator',
    roadmap: 'Roadmap',
    team: 'Team',
    github: 'GitHub',
};

// Note: /license route does not exist — link to /schemas-and-sources/ (existing route).
const columns = [
    {
        title: t.project,
        links: [
            { label: t.about,   href: prefix + '/about/' },
            { label: t.blog,    href: prefix + '/blog/' },
            { label: t.license, href: prefix + '/schemas-and-sources/' },
        ],
    },
    {
        title: t.resources,
        links: [
            { label: t.quickstart,    href: prefix + '/quickstart/quickstart/' },
            { label: t.specification, href: prefix + '/specification/overview/' },
            { label: t.configurator,  href: prefix + '/configurator/', badge: 'Demo' },
        ],
    },
    {
        title: t.community,
        links: [
            { label: t.roadmap, href: prefix + '/roadmap/' },
            { label: t.team,    href: prefix + '/team/' },
            { label: t.github,  href: 'https://github.com/FlowMCP', external: true },
        ],
    },
];
---

<footer class="pencil-footer">
    <div class="pencil-footer__widget">
        {columns.map( ( col ) => (
            <div class="pencil-footer__col">
                <h3 class="pencil-footer__col-title">{col.title}</h3>
                <ul class="pencil-footer__col-list">
                    {col.links.map( ( link ) => (
                        <li>
                            {link.external ? (
                                <a href={link.href} rel="noopener" target="_blank">{link.label}</a>
                            ) : (
                                <a href={link.href}>{link.label}{link.badge && <span class="pencil-footer__badge">{link.badge}</span>}</a>
                            )}
                        </li>
                    ) )}
                </ul>
            </div>
        ) )}
    </div>
    <div class="pencil-footer__inner">
        <div class="pencil-footer__brand">
            <span class="pencil-footer__logo">FlowMCP</span>
            <span class="pencil-footer__sep">·</span>
            <span class="pencil-footer__copy">{copy}</span>
        </div>
        <a class="pencil-footer__github" href="https://github.com/FlowMCP" rel="noopener" target="_blank" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.6.5.5 5.6.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2.9-.3 2-.4 3-.4 1 0 2 .1 3 .4 2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.1 0 4.6-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.6 18.4.5 12 .5z"/>
            </svg>
        </a>
    </div>
</footer>

<style>
.pencil-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-canvas);
    padding: 2rem 0 1.25rem;
    margin-top: 4rem;
}
.pencil-footer__widget {
    max-width: 1100px;
    margin: 0 auto 1.5rem;
    padding: 0 1.5rem;
    display: grid;
    /* Memo 124 Kap 11 (F5=B): equal thirds so the three zones are evenly distributed
     * (left / center / right) instead of a floating auto-width middle column. */
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    align-items: start;
}
/* Memo 088 Kap. 18: 3-Zonen-Ausrichtung — links / zentriert / rechts. */
.pencil-footer__widget .pencil-footer__col:nth-child(1) {
    text-align: left;
}
.pencil-footer__widget .pencil-footer__col:nth-child(2) {
    text-align: center;
}
.pencil-footer__widget .pencil-footer__col:nth-child(3) {
    text-align: right;
}
.pencil-footer__widget .pencil-footer__col:nth-child(1) .pencil-footer__col-list {
    align-items: flex-start;
}
.pencil-footer__widget .pencil-footer__col:nth-child(2) .pencil-footer__col-list {
    align-items: center;
}
.pencil-footer__widget .pencil-footer__col:nth-child(3) .pencil-footer__col-list {
    align-items: flex-end;
}
.pencil-footer__col-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
}
.pencil-footer__col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}
.pencil-footer__col-list a {
    color: var(--text-inactive);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s;
}
.pencil-footer__col-list a:hover {
    color: var(--text-primary);
}
/* Memo 127 follow-up: Demo badge next to the Data Configurator link */
.pencil-footer__badge {
    display: inline-block;
    margin-left: 0.4rem;
    padding: 1px 6px;
    background: var(--sidebar-active-bg);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    vertical-align: middle;
}
.pencil-footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem 0;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
}
.pencil-footer__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 13px;
}
.pencil-footer__logo {
    font-weight: 700;
    color: var(--text-primary);
}
.pencil-footer__sep {
    color: var(--group-title);
}
.pencil-footer__copy {
    color: var(--text-inactive);
}
.pencil-footer__github {
    color: var(--text-inactive);
    display: inline-flex;
    align-items: center;
}
.pencil-footer__github:hover {
    color: var(--text-primary);
}
@media (max-width: 768px) {
    .pencil-footer__widget {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }
    /* Memo 088 Kap. 18: gestapelt + alle Zonen zentriert (Desktop-Regeln ueberschreiben). */
    .pencil-footer__widget .pencil-footer__col:nth-child(1),
    .pencil-footer__widget .pencil-footer__col:nth-child(2),
    .pencil-footer__widget .pencil-footer__col:nth-child(3) {
        text-align: center;
    }
    .pencil-footer__widget .pencil-footer__col:nth-child(1) .pencil-footer__col-list,
    .pencil-footer__widget .pencil-footer__col:nth-child(2) .pencil-footer__col-list,
    .pencil-footer__widget .pencil-footer__col:nth-child(3) .pencil-footer__col-list {
        align-items: center;
    }
}
@media (max-width: 640px) {
    .pencil-footer__inner {
        flex-direction: row;
        justify-content: space-between;
    }
    .pencil-footer__brand {
        font-size: 12px;
    }
}
</style>
</content>
</invoke>