---
// LogoStrip — "Connects to" Logo-Strip (PRD-09, Memo 045 REV-14 Punkt 3)
// Pencil-Anker: Frame Gdy0k Landing Desktop v2 Dark
// Pencil: Formate, nicht Provider (User-Korrektur)
const providers = [
    { label: 'JSON',    icon: '{ }' },
    { label: 'XML',     icon: '〈/〉' },
    { label: 'SQLite',  icon: '🗃' },
    { label: 'GTFS',    icon: '🚇' },
    { label: 'CSV',     icon: '⊞' },
]
---

<div class="logo-strip">
    <span class="logo-strip__label">Connects to</span>
    <ul class="logo-strip__list">
        {providers.map((p) => (
            <li class="logo-strip__item">
                <span class="logo-strip__icon" aria-hidden="true">{p.icon}</span>
                <span class="logo-strip__name">{p.label}</span>
            </li>
        ))}
        <li class="logo-strip__item logo-strip__item--more">
            <a href="/docs/schemas/tags-reference/">+ more →</a>
        </li>
    </ul>
</div>

<style>
.logo-strip {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.5rem;
    background: transparent;
    margin: 0.5rem auto 1.5rem;
    max-width: 1100px;
    flex-wrap: wrap;
    justify-content: center;
}

.logo-strip__label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--group-title);
    font-weight: 700;
    white-space: nowrap;
}

.logo-strip__list {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: center;
}

.logo-strip__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.9rem;
    background: var(--bg-canvas);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 500;
}

.logo-strip__icon {
    font-size: 16px;
    line-height: 1;
}

.logo-strip__item--more {
    background: transparent;
    border-color: transparent;
}

.logo-strip__item--more a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
}

.logo-strip__item--more a:hover {
    filter: brightness(0.85);
}

@media (max-width: 640px) {
    .logo-strip {
        gap: 1rem;
        padding: 1rem;
    }

    .logo-strip__item {
        padding: 0.4rem 0.7rem;
        font-size: 13px;
    }
}
</style>
