---
// Hero — Pencil-Stil Landing Hero (Pencil-Mockup Gdy0k, Memo 045 REV-15)
// i18n: EN (default) + DE
const path = Astro.url.pathname;
const isDE = path.startsWith('/de/') || path === '/de';

const t = isDE ? {
    pill: 'FlowMCP v4.0 · Ankündigung lesen',
    headlineLine1: 'Beliebige Datenquellen',
    headlineLine2: 'für KI-Agenten.',
    tagline: '288 Datenquellen · 1.534 KI-aufrufbare Tools · KI-nativ, fuer tiefe Recherche.',
    ctaPrimary: 'Dokumentation lesen →',
    ctaSecondary: 'FlowMCP GPT fragen',
    trust: 'Open Source · MIT · GitHub-nativ · Kein Vendor-Lock-in',
    hackathon: 'Eingesetzt beim Berlin Mobility Hackathon 2026 · DB InfraGO',
    docsHref: '/de/quickstart/what-is-flowmcp/',
    blogHref: '/de/blog/',
} : {
    pill: 'FlowMCP v4.0 · Read the announcement',
    headlineLine1: 'Normalize any data source',
    headlineLine2: 'for AI agents.',
    tagline: '288 data sources · 1,534 AI-callable tools · AI-native, built for deep research.',
    ctaPrimary: 'Read the Docs →',
    ctaSecondary: 'Ask FlowMCP GPT',
    trust: 'Open source · MIT · GitHub-native · No vendor lock-in',
    hackathon: 'Used at Berlin Mobility Hackathon 2026 · DB InfraGO',
    docsHref: '/quickstart/what-is-flowmcp/',
    blogHref: '/blog/',
};
---

<div class="pencil-hero">
    <a class="pencil-hero__pill" href={t.blogHref}>
        <span class="pencil-hero__pill-icon">✦</span>
        {t.pill}
    </a>

    <h1 class="pencil-hero__headline">
        {t.headlineLine1}<br/>{t.headlineLine2}
    </h1>

    <p class="pencil-hero__tagline">
        {t.tagline}
    </p>

    <div class="pencil-hero__actions">
        <a class="pencil-hero__cta pencil-hero__cta--primary" href={t.docsHref}>
            {t.ctaPrimary}
        </a>
        <a class="pencil-hero__cta pencil-hero__cta--secondary" href="https://chatgpt.com/g/g-6a109541073c8191a60d6b3af20bcad7-flowmcp-guide" rel="noopener" target="_blank">
            {t.ctaSecondary}
        </a>
    </div>

    <p class="pencil-hero__trust">{t.trust}</p>
    <p class="pencil-hero__hackathon">{t.hackathon}</p>
</div>

<style>
.pencil-hero {
    position: relative;
    isolation: isolate;
    text-align: center;
    max-width: 1000px;
    margin: 1rem auto 1rem;
    padding: 0 1.5rem;
}

.pencil-hero::before {
    content: '';
    position: absolute;
    inset: -2rem;
    z-index: -1;
    pointer-events: none;
    border-radius: 24px;
    background: radial-gradient(
        circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
        color-mix(in srgb, var(--accent) 12%, transparent) 0%,
        color-mix(in srgb, var(--accent) 4%, transparent) 35%,
        transparent 70%
    );
    opacity: 0.55;
    animation: pencil-hero-pulse 8s ease-in-out infinite;
    transition: background-position 0.6s ease-out;
}

@keyframes pencil-hero-pulse {
    0%, 100% { opacity: 0.45; transform: scale(1); }
    50%      { opacity: 0.70; transform: scale(1.02); }
}

@media (prefers-reduced-motion: reduce) {
    .pencil-hero::before {
        animation: none;
        opacity: 0.5;
    }
}

.pencil-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    background: var(--sidebar-active-bg);
    color: var(--accent);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 2.5rem;
    text-decoration: none;
}

.pencil-hero__pill:hover { filter: brightness(1.15); }
.pencil-hero__pill-icon { font-size: 10px; }

/* .pencil-hero__headline — siehe custom.css HERO HEADLINE OVERRIDE Block */

.pencil-hero__tagline {
    font-size: 20px;
    color: var(--text-inactive);
    margin: 0 auto 2.5rem;
    max-width: 680px;
    line-height: 1.5;
}

.pencil-hero__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
}

.pencil-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.15s;
}

.pencil-hero__cta--primary {
    background: var(--accent);
    color: var(--bg-canvas) !important;
}
.pencil-hero__cta--primary:hover { filter: brightness(0.9); }

.pencil-hero__cta--secondary {
    background: transparent;
    color: var(--text-primary) !important;
    border: 1px solid var(--border);
}
.pencil-hero__cta--secondary:hover {
    border-color: var(--accent);
    color: var(--accent) !important;
}

.pencil-hero__trust {
    font-size: 12px;
    color: var(--text-inactive);
    margin: 0;
}

.pencil-hero__hackathon {
    font-size: 11px;
    color: var(--text-inactive);
    font-weight: 500;
    margin-top: 0.2rem;
}

@media (max-width: 640px) {
    .pencil-hero { margin: 3rem auto 2rem; }
    .pencil-hero__pill { font-size: 11px; }
    /* .pencil-hero__headline mobile rule — siehe custom.css HERO HEADLINE OVERRIDE */
    .pencil-hero__tagline { font-size: 14px; }
    .pencil-hero::before {
        animation-duration: 10s;
        opacity: 0.4;
    }
}
</style>

<script>
    if ( matchMedia( '(hover: hover)' ).matches && !matchMedia( '(prefers-reduced-motion: reduce)' ).matches ) {
        const hero = document.querySelector( '.pencil-hero' )
        if ( hero ) {
            let pendingFrame = null
            hero.addEventListener( 'mousemove', ( event ) => {
                if ( pendingFrame ) return
                pendingFrame = requestAnimationFrame( () => {
                    const rect = hero.getBoundingClientRect()
                    const x = ( ( event.clientX - rect.left ) / rect.width ) * 100
                    const y = ( ( event.clientY - rect.top ) / rect.height ) * 100
                    hero.style.setProperty( '--mouse-x', x + '%' )
                    hero.style.setProperty( '--mouse-y', y + '%' )
                    pendingFrame = null
                } )
            } )
            hero.addEventListener( 'mouseleave', () => {
                hero.style.setProperty( '--mouse-x', '50%' )
                hero.style.setProperty( '--mouse-y', '50%' )
            } )
        }
    }
</script>
