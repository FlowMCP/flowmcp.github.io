---
// CopyMarkdown.astro — Memo 060 Phase 7 PRD-021
// Reusable Astro component that copies markdown content to the clipboard.
//
// Two modes:
//   - mode="page" (default): fetches /markdown-sources/{slug}.md and copies the response
//   - mode="slot":            copies the rendered slot content (e.g. a skill snippet)
//
// Browser compatibility:
//   - Primary: navigator.clipboard.writeText (requires window.isSecureContext)
//   - Fallback: hidden <textarea> + document.execCommand('copy')
//
// Visual feedback: button text changes to "Copied!" / "Kopiert!" for 2s, then reverts.
// On failure: "Copy failed" / "Fehlgeschlagen" for 3s + console.error.

interface Props {
    slug?: string
    lang?: 'en' | 'de'
    label?: string
    mode?: 'page' | 'slot'
}

const {
    slug: slugProp,
    lang = 'en',
    label: labelProp,
    mode = 'page'
} = Astro.props

// Slug fallback: derive from current pathname when not explicitly passed
const derivedSlug = ( () => {
    if( typeof slugProp === 'string' && slugProp.length > 0 ) { return slugProp }
    const pathname = Astro.url?.pathname ?? ''
    return pathname.replace( /^\/+|\/+$/g, '' )
} )()

const DEFAULTS = {
    page: {
        en: { idle: 'Copy page as Markdown', done: 'Copied!', fail: 'Copy failed', aria: 'Copy page content as Markdown' },
        de: { idle: 'Seite als Markdown kopieren', done: 'Kopiert!', fail: 'Fehlgeschlagen', aria: 'Seiteninhalt als Markdown kopieren' }
    },
    slot: {
        en: { idle: 'Copy this skill', done: 'Copied!', fail: 'Copy failed', aria: 'Copy skill snippet to clipboard' },
        de: { idle: 'Skill kopieren', done: 'Kopiert!', fail: 'Fehlgeschlagen', aria: 'Skill-Snippet in die Zwischenablage kopieren' }
    }
}

const labels = DEFAULTS[ mode ][ lang ]
const idleLabel = typeof labelProp === 'string' && labelProp.length > 0 ? labelProp : labels.idle
const doneLabel = labels.done
const failLabel = labels.fail
const ariaLabel = labels.aria
---

<div class="copy-markdown" data-copy-mode={mode}>
    {mode === 'slot' && (
        <pre class="copy-markdown__slot" data-copy-content style="display:none"><slot /></pre>
    )}
    <button
        type="button"
        class="copy-markdown__button"
        data-copy-markdown
        data-copy-mode={mode}
        data-copy-slug={mode === 'page' ? derivedSlug : ''}
        data-copy-lang={lang}
        data-label-idle={idleLabel}
        data-label-done={doneLabel}
        data-label-fail={failLabel}
        aria-label={ariaLabel}
    >
        <span class="copy-markdown__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
        </span>
        <span class="copy-markdown__label">{idleLabel}</span>
    </button>
</div>

<style>
    .copy-markdown {
        display: inline-flex;
        margin: 0.5rem 0 1rem;
    }

    .copy-markdown__button {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.8rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--sl-color-text, #cfcfcf);
        background: var(--sl-color-bg-nav, #1f1f1f);
        border: 1px solid var(--sl-color-hairline, #333);
        border-radius: 6px;
        cursor: pointer;
        transition: background 120ms ease, border-color 120ms ease;
    }

    .copy-markdown__button:hover {
        background: var(--sl-color-bg-sidebar, #2a2a2a);
        border-color: var(--sl-color-accent, #6aaaff);
    }

    .copy-markdown__button[data-state="done"] {
        color: var(--sl-color-accent, #6aaaff);
        border-color: var(--sl-color-accent, #6aaaff);
    }

    .copy-markdown__button[data-state="fail"] {
        color: #e35454;
        border-color: #e35454;
    }

    .copy-markdown__icon {
        display: inline-flex;
        align-items: center;
    }
</style>

<script>
    const STATE_DURATION_MS = 2000
    const FAIL_DURATION_MS = 3000

    const fallbackCopy = ( text ) => {
        const textarea = document.createElement( 'textarea' )
        textarea.value = text
        textarea.setAttribute( 'readonly', '' )
        textarea.style.position = 'absolute'
        textarea.style.left = '-9999px'
        document.body.appendChild( textarea )
        textarea.select()
        let ok = false
        try {
            ok = document.execCommand( 'copy' )
        } catch( err ) {
            ok = false
        }
        document.body.removeChild( textarea )
        return ok
    }

    const writeToClipboard = async ( text ) => {
        if( navigator.clipboard && window.isSecureContext ) {
            try {
                await navigator.clipboard.writeText( text )
                return true
            } catch( err ) {
                // fall through to fallback
                console.warn( '[CopyMarkdown] navigator.clipboard failed, using fallback', err )
            }
        }
        return fallbackCopy( text )
    }

    const setState = ( { button, labelEl, state, text } ) => {
        button.setAttribute( 'data-state', state )
        labelEl.textContent = text
    }

    const revertState = ( { button, labelEl, idleLabel } ) => {
        button.removeAttribute( 'data-state' )
        labelEl.textContent = idleLabel
    }

    const getSlotContent = ( button ) => {
        const wrapper = button.closest( '.copy-markdown' )
        if( !wrapper ) { return '' }
        const slotEl = wrapper.querySelector( '[data-copy-content]' )
        if( !slotEl ) { return '' }
        return slotEl.textContent || ''
    }

    const getPageMarkdown = async ( slug ) => {
        if( !slug ) { throw new Error( 'CopyMarkdown: missing slug for page mode' ) }
        const trimmed = slug.replace( /^\/+|\/+$/g, '' )
        const url = `/markdown-sources/${ trimmed }.md`
        const response = await fetch( url )
        if( !response.ok ) {
            throw new Error( `CopyMarkdown: fetch ${ url } failed with HTTP ${ response.status }` )
        }
        return await response.text()
    }

    const handleClick = async ( event ) => {
        const button = event.currentTarget
        const labelEl = button.querySelector( '.copy-markdown__label' )
        if( !labelEl ) { return }
        const idleLabel = button.getAttribute( 'data-label-idle' ) || ''
        const doneLabel = button.getAttribute( 'data-label-done' ) || 'Copied!'
        const failLabel = button.getAttribute( 'data-label-fail' ) || 'Copy failed'
        const mode = button.getAttribute( 'data-copy-mode' ) || 'page'

        let payload = ''
        try {
            if( mode === 'slot' ) {
                payload = getSlotContent( button )
            } else {
                const slug = button.getAttribute( 'data-copy-slug' ) || ''
                payload = await getPageMarkdown( slug )
            }
        } catch( err ) {
            console.error( '[CopyMarkdown] payload resolution failed', err )
            setState( { button, labelEl, state: 'fail', text: failLabel } )
            setTimeout( () => revertState( { button, labelEl, idleLabel } ), FAIL_DURATION_MS )
            return
        }

        const ok = await writeToClipboard( payload )
        if( ok ) {
            setState( { button, labelEl, state: 'done', text: doneLabel } )
            setTimeout( () => revertState( { button, labelEl, idleLabel } ), STATE_DURATION_MS )
        } else {
            console.error( '[CopyMarkdown] clipboard write failed for mode', mode )
            setState( { button, labelEl, state: 'fail', text: failLabel } )
            setTimeout( () => revertState( { button, labelEl, idleLabel } ), FAIL_DURATION_MS )
        }
    }

    const init = () => {
        const buttons = document.querySelectorAll( 'button[data-copy-markdown]' )
        buttons.forEach( ( button ) => {
            if( button.dataset.copyBound === '1' ) { return }
            button.dataset.copyBound = '1'
            button.addEventListener( 'click', handleClick )
        } )
    }

    if( document.readyState === 'loading' ) {
        document.addEventListener( 'DOMContentLoaded', init )
    } else {
        init()
    }
</script>
