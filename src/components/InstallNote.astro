---
import refs from '../data/refs.json';


interface Props {
    repo: string;
    global?: boolean;
    scope?: string;
    pinTag?: boolean;
}

const { repo, global = false, scope = 'FlowMCP', pinTag = false } = Astro.props;
const flag = global ? ' -g' : '';

let tagSuffix = '';
if( pinTag ) {
    const importString = refs?.imports?.cli?.github;
    if( !importString || typeof importString !== 'string' ) {
        throw new Error( 'InstallNote: pinTag=true but refs.imports.cli.github missing in src/data/refs.json' );
    }
    const hashIndex = importString.indexOf( '#' );
    if( hashIndex === -1 ) {
        throw new Error( `InstallNote: pinTag=true but refs.imports.cli.github has no #<tag> suffix (got "${ importString }")` );
    }
    tagSuffix = importString.slice( hashIndex );
}
---

<div class="install-note">
    <p class="install-note__label">Install via GitHub:</p>
    <pre><code>npm install{flag} github:{scope}/{repo}{tagSuffix}</code></pre>
    <p class="install-note__hint">FlowMCP packages are not published to NPM. They are installed directly from GitHub.</p>
</div>

<style>
    .install-note {
        margin: 1rem 0;
        padding: 1rem;
        border-left: 3px solid var(--sl-color-accent);
        background: var(--sl-color-bg-nav);
        border-radius: 4px;
    }

    .install-note__label {
        margin: 0 0 0.5rem;
        font-weight: 600;
    }

    .install-note pre {
        margin: 0;
    }

    .install-note__hint {
        font-size: 0.85rem;
        color: var(--sl-color-text-muted);
        margin: 0.5rem 0 0;
    }
</style>
