---
// StatsBar — Pencil-Stil (Frame Gdy0k, REV-05 Kap. 2.1)
// KEINE Kacheln (User-Entscheidung REV-03). 3 Spalten (Memo 057 PRD-13: Provider-Kategorien Cell entfernt).
const path = Astro.url.pathname
const isDE = path.startsWith( '/de/' ) || path === '/de'

// Stats source: .memo/058-content-strecke/rollout/stats-verification.md (2026-05-24)
// 365 schemas (v4 production), 288 providers, 3,102 callable tools
const stats = [
    { value: '288',    label: isDE ? 'Datenquellen'           : 'Data sources' },
    { value: '3,100+', label: isDE ? 'KI-aufrufbare Tools'    : 'AI-callable tools' },
    { value: 'MIT',    label: isDE ? 'Open-Source-Lizenz'     : 'Open source license' },
]
---

<section class="stats-bar" aria-label="FlowMCP at a glance">
    {stats.map( ( s ) => (
        <div class="stats-bar__cell">
            <div class="stats-bar__value">{s.value}</div>
            <div class="stats-bar__label">{s.label}</div>
        </div>
    ) )}
</section>

<style>
.stats-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
    gap: 3rem;
    margin: 2rem auto 3rem;
    max-width: 1100px;
    padding: 0 1.5rem;
}

.stats-bar__cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 0.6rem;
    min-height: 130px;
    margin-top: 0;
    /* KEIN background, KEINE border, KEIN border-radius — Pencil-Paritaet */
}

/* Starlight reset: kill sibling-margin on stats cells */
.stats-bar > .stats-bar__cell + .stats-bar__cell {
    margin-top: 0;
}

.stats-bar__value {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
}

.stats-bar__label {
    font-size: 13px;
    color: var(--text-inactive);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 500;
}

@media (max-width: 640px) {
    .stats-bar {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        padding: 0 1rem;
    }
    .stats-bar__value {
        font-size: 1.75rem;
    }
    .stats-bar__label {
        font-size: 11px;
    }
}
</style>
