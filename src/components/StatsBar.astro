---
// StatsBar — 4-Spalten Stats (Pencil-Mockup Gdy0k, Memo 045 REV-15 Punkt 4)
// Jede Spalte in eigener Kachel (User-Feedback: Hintergrund-Kacheln nötig)
const path = Astro.url.pathname;
const isDE = path.startsWith('/de/') || path === '/de';

const stats = [
    { value: '288',    label: isDE ? 'Datenquellen'           : 'Data sources' },
    { value: '1,534',  label: isDE ? 'KI-aufrufbare Tools'    : 'AI-callable tools' },
    { value: '13',     label: isDE ? 'Provider-Kategorien'    : 'Provider categories' },
    { value: 'MIT',    label: isDE ? 'Open-Source-Lizenz'     : 'Open source license' },
]
---

<section class="stats-bar" aria-label="FlowMCP at a glance">
    {stats.map((s) => (
        <div class="stats-bar__tile">
            <div class="stats-bar__value">{s.value}</div>
            <div class="stats-bar__label">{s.label}</div>
        </div>
    ))}
</section>

<style>
.stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 2rem auto 3rem;
    max-width: 1100px;
    padding: 0 1.5rem;
}

.stats-bar__tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
    padding: 1.5rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
}

.stats-bar__value {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
}

.stats-bar__label {
    font-size: 12px;
    color: var(--text-inactive);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

@media (max-width: 640px) {
    .stats-bar {
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        padding: 0 1rem;
    }
    .stats-bar__tile {
        padding: 1.25rem 0.75rem;
    }
    .stats-bar__value {
        font-size: 1.75rem;
    }
    .stats-bar__label {
        font-size: 10px;
    }
}
</style>
