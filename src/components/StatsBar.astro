---
// StatsBar — 4-Spalten Stats (PRD-10, Memo 045 REV-14 Punkt 4)
// Pencil-Anker: Frame Gdy0k Landing Desktop v2 Dark
const stats = [
    { value: '288',    label: 'Data sources' },
    { value: '1,534',  label: 'AI-callable tools' },
    { value: '13',     label: 'Provider categories' },
    { value: 'MIT',    label: 'Open source license' },
]
---

<section class="stats-bar" aria-label="FlowMCP at a glance">
    {stats.map((s) => (
        <div class="stats-bar__item">
            <div class="stats-bar__value">{s.value}</div>
            <div class="stats-bar__label">{s.label}</div>
        </div>
    ))}
</section>

<style>
.stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding: 2rem 1.5rem;
    background: transparent;
    margin: 2rem auto 3rem;
    max-width: 1100px;
}

.stats-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
}

.stats-bar__value {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
}

.stats-bar__label {
    font-size: 13px;
    color: var(--text-inactive);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

@media (max-width: 640px) {
    .stats-bar {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
        padding: 1.5rem 1rem;
    }

    .stats-bar__value {
        font-size: 2rem;
    }

    .stats-bar__label {
        font-size: 11px;
    }
}
</style>
