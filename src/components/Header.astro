---
// Custom Header — Pencil-Style (PRD-04, REV-05 Kap. 4)
// Adapted from @astrojs/starlight/components/Header.astro
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';

const shouldRenderSearch =
    config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const path = Astro.url.pathname;
const isDE = path.startsWith('/de/') || path === '/de';
const prefix = isDE ? '/de' : '';

// Memo 059 PRD-010 + PRD-013: Top-Nav reduced to About / Docs / Blog.
// Roadmap and Team moved to Footer-Widget (PRD-012).
// PRD-013 audit: DE-Mirror complete — navLinks branch on isDE; both locales
// show 3 entries. EN: About/Docs/Blog. DE: Über/Docs/Blog.
// Memo 127 follow-up: the Data Configurator lives in the FOOTER (Resources) with a Demo
// badge, not in the top nav — keeps the header lean while it is still an early demo.
const navLinks = isDE ? [
    { text: 'Über',  href: prefix + '/about/',                      match: '/about' },
    { text: 'Docs',  href: prefix + '/quickstart/what-is-flowmcp/', match: '/quickstart' },
    { text: 'Blog',  href: prefix + '/blog/',                       match: '/blog' },
] : [
    { text: 'About', href: prefix + '/about/',                      match: '/about' },
    { text: 'Docs',  href: prefix + '/quickstart/what-is-flowmcp/', match: '/quickstart' },
    { text: 'Blog',  href: prefix + '/blog/',                       match: '/blog' },
];
---

<div class="header pencil-header">
    <div class="header__left">
        <div class="title-wrapper sl-flex">
            <SiteTitle />
            <span class="v4-badge">v4</span>
        </div>
        <nav class="header__nav sl-hidden md:sl-flex" aria-label="Main navigation">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class={`header__nav-link ${path.indexOf(link.match) !== -1 ? 'is-active' : ''}`}
                >
                    {link.text}
                </a>
            ))}
        </nav>
    </div>

    <div class="sl-flex print:hidden header__search">
        {shouldRenderSearch && <Search />}
    </div>

    <div class="sl-hidden md:sl-flex print:hidden right-group">
        <LanguageSelect />
    </div>
</div>

<style>
    .pencil-header {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        height: 100%;
    }

    .header__left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .title-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        overflow: clip;
        padding: 0.25rem;
        margin: -0.25rem;
        min-width: 0;
    }

    .v4-badge {
        display: inline-block;
        padding: 2px 7px;
        background: var(--sidebar-active-bg);
        color: var(--accent);
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        line-height: 1;
    }

    .header__nav {
        display: flex;
        gap: 1.25rem;
        align-items: center;
    }

    .header__nav-link {
        color: var(--text-inactive);
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        padding: 0.25rem 0;
        transition: color 0.15s;
    }

    .header__nav-link:hover {
        color: var(--text-primary);
    }

    .header__nav-link.is-active {
        color: var(--text-primary);
        font-weight: 600;
    }

    .header__search {
        justify-self: end;
        max-width: 220px;
    }

    .right-group {
        gap: 0.75rem;
        align-items: center;
    }

    @media (max-width: 50rem) {
        .header__left {
            gap: 0.5rem;
        }
        .v4-badge {
            font-size: 9px;
            padding: 1px 5px;
        }
        .header__search {
            max-width: 100%;
        }
    }
</style>
