---
// Head Override — serverseitig data-theme=dark + Favicons
// PRD-08, REV-05 Kap. 8.4 (Chrome-Dark-Mode-Fix)
import Default from '@astrojs/starlight/components/Head.astro'
---

<meta name="color-scheme" content="dark" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
<Default><slot /></Default>
<script is:inline>
    // Force dark theme — overrides Starlight ThemeProvider auto-detection
    try { localStorage.setItem( 'starlight-theme', 'dark' ) } catch( e ) {}
    document.documentElement.setAttribute( 'data-theme', 'dark' )
    document.documentElement.dataset.theme = 'dark'
</script>

<script is:inline>
    // Memo 057 PRD-07 — Skip-Link as first interactive element on every page.
    // Injected client-side so it works across Starlight templates without
    // overriding internals. Targets the Starlight main content (.main-frame main
    // or any [role="main"] / main element).
    ( function() {
        const ensureSkipLink = () => {
            if( document.getElementById( 'flowmcp-skip-link' ) ) { return }
            const link = document.createElement( 'a' )
            link.id = 'flowmcp-skip-link'
            link.className = 'skip-link'
            link.href = '#main-content'
            link.textContent = 'Skip to main content'
            const body = document.body
            if( ! body ) { return }
            body.insertBefore( link, body.firstChild )
        }
        const ensureMainTarget = () => {
            // Find the primary <main> in Starlight templates and give it id+role
            const main = document.querySelector( 'main' )
            if( ! main ) { return }
            if( ! main.id ) { main.id = 'main-content' }
            if( main.getAttribute( 'role' ) !== 'main' ) {
                main.setAttribute( 'role', 'main' )
            }
        }
        const run = () => {
            ensureSkipLink()
            ensureMainTarget()
        }
        if( document.readyState === 'loading' ) {
            document.addEventListener( 'DOMContentLoaded', run )
        } else {
            run()
        }
        document.addEventListener( 'astro:page-load', run )
    } )()
</script>

<script>
    // Memo 057 PRD-07 — TOC a11y (aside aria-label + aria-current="location")
    import { initTocA11y } from '../scripts/toc-a11y.mjs'
    initTocA11y()
</script>
