---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>FlowMCP — Blog</title>
    <meta name="description" content="Releases, hackathon stories, and notes from the FlowMCP team." />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="alternate" type="application/rss+xml" title="FlowMCP Blog RSS" href="/rss.xml" />
    <link rel="stylesheet" href="/_astro/blog.css" />
</head>
<body>
    <main class="blog-index">
        <header class="blog-index__header">
            <h1>Blog</h1>
            <p>Releases, hackathon stories, integration guides.</p>
            <a class="blog-index__rss" href="/rss.xml">RSS Feed</a>
        </header>

        <ul class="blog-index__list">
            {posts.map((post) => (
                <li class="blog-index__item">
                    <a href={`/blog/${post.id}/`}>
                        <h2>{post.data.title}</h2>
                        <p class="blog-index__meta">
                            {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.author}
                        </p>
                        <p>{post.data.description}</p>
                        <ul class="blog-index__tags">
                            {post.data.tags.map((tag) => (
                                <li>#{tag}</li>
                            ))}
                        </ul>
                    </a>
                </li>
            ))}
        </ul>
    </main>

    <style is:global>
        body { background: #0d1117; color: #f0f6fc; font-family: Inter, sans-serif; margin: 0; }
        .blog-index { max-width: 800px; margin: 4rem auto; padding: 0 1.5rem; }
        .blog-index__header h1 { font-size: 2.5rem; margin: 0; color: #f0f6fc; }
        .blog-index__header p { color: #8b949e; margin: 0.5rem 0 1rem; }
        .blog-index__rss { color: #79c0ff; text-decoration: none; font-size: 14px; font-weight: 600; }
        .blog-index__list { list-style: none; padding: 0; margin: 3rem 0 0; display: flex; flex-direction: column; gap: 1.5rem; }
        .blog-index__item a { display: block; padding: 1.5rem; background: #161b22; border: 1px solid #30363d; border-radius: 12px; text-decoration: none; color: inherit; }
        .blog-index__item a:hover { border-color: #79c0ff; }
        .blog-index__item h2 { margin: 0; color: #f0f6fc; font-size: 1.5rem; }
        .blog-index__meta { color: #8b949e; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0.5rem 0; }
        .blog-index__tags { list-style: none; padding: 0; margin: 0.75rem 0 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
        .blog-index__tags li { font-size: 12px; color: #79c0ff; }
    </style>
</body>
</html>
