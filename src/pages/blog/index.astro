---
import { getCollection } from 'astro:content'
import BlogTopnav from '../../components/BlogTopnav.astro'

// Show drafts in dev mode for local review; hide in production builds.
const showDrafts = import.meta.env.DEV
const posts = ( await getCollection( 'blog', ( { data } ) => showDrafts || !data.draft ) )
    .sort( ( a, b ) => b.data.date.valueOf() - a.data.date.valueOf() )

const featured = posts[ 0 ]
const rest = posts.slice( 1 )

const filterTabs = [ 'All', 'Releases', 'Tutorials', 'Hackathon', 'Architecture', 'Case Studies' ]
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog — FlowMCP</title>
    <meta name="description" content="Releases, hackathon stories, integration guides — from the FlowMCP team." />
    <link rel="canonical" href="/blog/" />
    <meta property="og:title" content="Blog — FlowMCP" />
    <meta property="og:description" content="Releases, hackathon stories, integration guides — from the FlowMCP team." />
    <meta property="og:url" content="/blog/" />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title="FlowMCP Blog" href="/blog/rss.xml" />
    <link rel="stylesheet" href="/_styles/global.css" />
</head>
<body>
<BlogTopnav active="blog" />

<main class="blog-index" id="main-content" role="main">
    <header class="blog-index__header">
        <h1 class="blog-index__title">Blog</h1>
        <p class="blog-index__subtitle">Updates, tutorials, and release notes for FlowMCP.</p>
        <a class="blog-index__rss" href="/blog/rss.xml">RSS Feed →</a>
    </header>

    <nav class="blog-index__filters" aria-label="Blog filter">
        {filterTabs.map( ( tab, i ) => (
            <button class={`blog-index__filter ${i === 0 ? 'is-active' : ''}`} data-filter={tab}>
                {tab}
            </button>
        ) )}
    </nav>

    {featured && (
        <a class="blog-index__featured" href={`/blog/${featured.id}/`}>
            <span class="blog-index__featured-badge">FEATURED</span>
            <h2 class="blog-index__featured-title">{featured.data.title}</h2>
            <p class="blog-index__featured-desc">{featured.data.description}</p>
            <span class="blog-index__featured-cta">Read more →</span>
        </a>
    )}

    {rest.length > 0 && (
        <div class="blog-index__grid">
            {rest.map( ( post ) => (
                <a class="blog-index__card" href={`/blog/${post.id}/`}>
                    <span class="blog-index__card-tag">{post.data.tags[ 0 ] || 'post'}</span>
                    <h3 class="blog-index__card-title">{post.data.title}</h3>
                    <p class="blog-index__card-desc">{post.data.description}</p>
                </a>
            ) )}
        </div>
    )}
</main>

<style is:global>
:root {
    --bg-canvas: #0d1117;
    --bg-card: #161b22;
    --border: #30363d;
    --text-primary: #f0f6fc;
    --text-inactive: #8b949e;
    --accent: #79c0ff;
    --sidebar-active-bg: rgba(121, 192, 255, 0.12);
}

* { box-sizing: border-box }
body {
    background: var(--bg-canvas);
    color: var(--text-primary);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, system-ui, sans-serif;
    margin: 0;
    line-height: 1.6;
}

.blog-index {
    max-width: 1100px;
    margin: 2rem auto 4rem;
    padding: 0 1.5rem;
}

.blog-index__header { margin-bottom: 1.5rem; }
.blog-index__title { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--text-primary); margin: 0 0 0.5rem; }
.blog-index__subtitle { color: var(--text-inactive); font-size: 16px; margin: 0 0 1rem; }
.blog-index__rss { color: var(--accent); text-decoration: none; font-size: 13px; font-weight: 600; }

.blog-index__filters { display: flex; gap: 0.5rem; margin: 2rem 0; flex-wrap: wrap; }
.blog-index__filter { padding: 0.4rem 1rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 999px; color: var(--text-inactive); font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
.blog-index__filter:hover { border-color: var(--accent); color: var(--accent); }
.blog-index__filter.is-active { background: var(--sidebar-active-bg); color: var(--accent); border-color: var(--accent); }

.blog-index__featured { display: block; padding: 2rem; background: linear-gradient(135deg, #1c2e4a 0%, #161b22 100%); border: 1px solid var(--accent); border-radius: 12px; margin-bottom: 2rem; text-decoration: none; color: inherit; transition: all 0.15s; }
.blog-index__featured:hover { transform: translateY(-2px); }
.blog-index__featured-badge { display: inline-block; padding: 0.2rem 0.6rem; background: var(--accent); color: var(--bg-canvas); border-radius: 4px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; margin-right: 1rem; }
.blog-index__featured-title { font-size: 1.8rem; font-weight: 700; color: var(--text-primary); margin: 0.75rem 0; }
.blog-index__featured-desc { color: var(--text-inactive); font-size: 15px; line-height: 1.6; margin: 0 0 1rem; }
.blog-index__featured-cta { color: var(--accent); font-weight: 600; font-size: 14px; }

.blog-index__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
.blog-index__card { display: block; padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; text-decoration: none; color: inherit; transition: all 0.15s; }
.blog-index__card:hover { border-color: var(--accent); }
.blog-index__card-tag { display: inline-block; color: var(--accent); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.75rem; }
.blog-index__card-title { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; line-height: 1.3; }
.blog-index__card-desc { color: var(--text-inactive); font-size: 14px; line-height: 1.5; margin: 0 0 1rem; }
</style>
</body>
</html>
